{% extends "layout.html.twig" %}

{% block header %}
    {% include "partials/_header.html.twig" %}
{% endblock %}

{% block main %}

<div class="projects-page">
    <div class="projects-container">

        <header class="projects-header">
            <h1>Mes projets</h1>
            <p>Voici une sélection de mes projets personnels et professionnels.</p>
        </header>

        <div class="search-wrapper">
            <input type="text" id="searchInput" placeholder="Rechercher un projet..." class="search-input" >
        </div>

        {% set featuredProjects = projects|filter(p => p.featured is defined and p.featured) %}

        {% if featuredProjects is not empty %}

            <section class="section">

                <h2 class="section-title"><i class="fas fa-star"></i> Projets mis en avant</h2>

                <div class="grid">

                    {% for project in featuredProjects %}

                        <div class="card featured">

                            <div class="card-top">

                                <div class="icon"><i class="fas fa-rocket"></i></div>

                            </div>

                            <h3>{{ project.name }}</h3>

                            <p>{{ project.description }}</p>

                            <div class="tags">

                                {% if project.languages is defined %}

                                    {% for lang in project.languages %}
                                        <span class="tag">{{ lang }}</span>
                                    {% endfor %}

                                {% else %}
                                    <span class="tag">{{ project.language }}</span>
                                {% endif %}

                            </div>

                            <a class="link" href="{{ project.url }}" target="_blank">
                                Voir sur GitHub →
                            </a>

                        </div>

                    {% endfor %}

                </div>

            </section>

        {% endif %}


        <section class="section">

            <h2 class="section-title"><i class="fas fa-boxes"></i> Tous les projets</h2>

            <div class="grid">

                {% for project in projects %}

                    <div class="card">

                        <div class="card-top">
                            <div class="icon"><i class="fas fa-box"></i></div>

                            {% if project.featured is defined and project.featured %}
                                <span class="badge-star">Featured</span>
                            {% endif %}
                        </div>

                        <h3>{{ project.name }}</h3>

                        <p>{{ project.description }}</p>

                        <div class="tags">

                            {% if project.languages is defined %}

                                {% for lang in project.languages %}
                                    <span class="tag">{{ lang }}</span>
                                {% endfor %}

                            {% else %}
                                <span class="tag">{{ project.language }}</span>
                            {% endif %}

                        </div>

                        <a class="link" href="{{ project.url }}" target="_blank">
                            Voir sur GitHub →
                        </a>

                    </div>

                {% endfor %}

            </div>

        </section>


        <section class="cta">

            <div class="cta-box">

                <div>
                    <h3>Un projet en tête ?</h3>
                    <p>Je suis ouvert aux collaborations et nouvelles opportunités.</p>
                </div>

                <a href="index.php?route=contact" class="cta-btn">
                    Me contacter →
                </a>

            </div>

        </section>

    </div>

</div>

<script src="assets/js/searchBar.js" defer></script>

{% endblock %}