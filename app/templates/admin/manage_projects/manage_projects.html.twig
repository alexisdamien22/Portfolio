{% extends "layout.html.twig" %}

{% block header %}
    {% include "partials/_header.html.twig" %}
{% endblock %}

{% block main %}

<main class="admin-container">

    <section class="admin-header">

        <h1>Project Manager</h1>
        <p>Gère tes projets GitHub et custom</p>

        <div class="admin-search">
            <input type="text" id="adminSearch" placeholder="Rechercher un projet...">
        </div>

    </section>

    <div class="admin-actions top-actions">
        <button form="projectsForm" class="admin-btn"><i class="fas fa-save"></i> Sauvegarder</button>
        <a href="index.php?route=admin&action=syncGitHub" class="admin-btn"><i class="fas fa-sync-alt"></i> Synchroniser avec GitHub</a>
    </div>

    <form id="projectsForm" method="POST" action="index.php?route=admin&action=updateProjects">

        <div class="admin-grid">

            {% for project in projects %}

                <div class="admin-card">

                    <h3>{{ project.name }}</h3>

                    <p>{{ project.description }}</p>

                    <div class="admin-tags">
                        {% for lang in project.languages %}
                            <span class="admin-tag">{{ lang }}</span>
                        {% endfor %}
                    </div>

                    <div class="admin-switches">

                        <label class="toggle">
                            Visible

                            <label class="switch">
                                <input type="checkbox" name="visible[]" value="{{ project.name }}" {% if project.visible %}checked{% endif %}>
                                <span class="slider"></span>
                            </label>

                        </label>

                        <label class="toggle">
                            Featured

                            <label class="switch">
                                <input type="checkbox" name="featured[]" value="{{ project.name }}" {% if project.featured %}checked{% endif %}>
                                <span class="slider"></span>
                            </label>

                        </label>

                    </div>

                </div>

            {% endfor %}

        </div>

    </form>

</main>

<script src="assets/js/adminSearch.js" defer></script>

{% endblock %}