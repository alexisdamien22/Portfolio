{% extends "layout.html.twig" %}

{% block header %}
    {% include "partials/_header.html.twig" %}
{% endblock %}

{% block main %}

<h1>Project Manager</h1>

<form method="POST" action="index.php?route=admin&action=updateProjects">

<div class="projects-grid">

    {% for project in projects %}

        <div class="project-card">

            <h3>{{ project.name }}</h3>

            <p>{{ project.description }}</p>

            <div class="languages">
                {% for lang in project.languages %}
                    <span class="badge">{{ lang }}</span>
                {% endfor %}
            </div>

            <p>
                <a href="{{ project.url }}" target="_blank">
                    Voir sur GitHub
                </a>
            </p>

            <div class="toggles">

                <label>
                    <input type="checkbox"
                           name="visible[]"
                           value="{{ project.name }}"
                           {% if project.visible %}checked{% endif %}>
                    Visible
                </label>

                <label>
                    <input type="checkbox"
                           name="featured[]"
                           value="{{ project.name }}"
                           {% if project.featured %}checked{% endif %}>
                    Featured
                </label>

            </div>

        </div>

    {% endfor %}

</div>

<button type="submit"><i class="fas fa-save"></i> Sauvegarder</button>

<button type="button" onclick="location.href='index.php?route=admin&action=syncGitHub'">
    <i class="fas fa-sync-alt"></i> Synchroniser avec GitHub

</form>

{% endblock %}